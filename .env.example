OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required for the pr_review workflow.
# Leave blank to use unauthenticated requests (public repositories only, 60 req/hr).
# Set to a fine-grained personal access token with read-only access to pull requests
# for authenticated requests (public and private repositories, 5000 req/hr).
GITHUB_TOKEN=
